@model SistemaProyectos.ViewModels.HomeIndexViewModel

@{
    ViewData["Title"] = "Home Page";
}

@section Styles
{
   <style>
        .div5_MedidorProyecto canvas {
            width: 100% !important;
            height: 100% !important;
        }

        body {
            overflow-y: auto;
            background-color: #E6E6FA;
            margin: 0;
            padding: 0;
        }

        /* Contenedor principal optimizado */
        .container-fluid.col {
            padding: 0.5rem;
            height: calc(100vh - 60px); /* Resta la altura del navbar */
            display: flex;
            flex-direction: column;
        }

        /* Header de bienvenida más compacto */
        .welcome-header {
            margin-bottom: 0.5rem;
            padding: 0.5rem 0;
        }

            .welcome-header h2 {
                margin: 0;
                font-size: 1.5rem;
            }

        /* Grid principal responsivo con proporciones 25% - 75% */
        .parent {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            grid-template-rows: 1fr 3fr; /* 25% arriba, 75% abajo */
            height: calc(100vh - 120px); /* Altura dinámica */
            gap: 8px;
            flex-grow: 1;
        }

        .div1 {
            grid-column: span 2 / span 2;
            grid-row: 1; /* Primera fila (25%) */
            display: flex;
            flex-direction: column;
            background: white;
            border-radius: 8px;
            overflow: hidden;
        }

        .div2 {
            grid-column: 3;
            grid-row: 1; /* Primera fila (25%) */
            display: flex;
            flex-direction: column;
            background: white;
            border-radius: 8px;
            overflow: hidden;
        }

        .div3 {
            grid-column: span 2 / span 2;
            grid-row: 2; /* Segunda fila (75%) */
            background: white;
            border-radius: 8px;
            overflow: hidden;
        }

        .div4 {
            grid-column: 3;
            grid-row: 2; /* Segunda fila (75%) */
            background: white;
            border-radius: 8px;
            overflow: hidden;
        }

        /* Optimización de los carouseles */
        .carousel-section {
            display: flex;
            flex-direction: column;
            height: 100%;
            padding: 0.75rem;
        }

        .section-title {
            flex-shrink: 0;
            margin-bottom: 0.75rem;
            text-align: center;
        }

        .carousel-container {
            flex-grow: 1;
            position: relative;
            overflow: hidden;
        }

        .carousel.slide {
            height: 100%;
        }

        .carousel-inner {
            height: 100%;
        }

        .carousel-item {
            height: 100%;
            padding: 0.5rem;
        }

        /* Tarjetas de comentarios optimizadas */
        .comment-card {
            height: 100%;
            display: flex;
            flex-direction: column;
            border-radius: 8px;
            overflow: hidden;
        }

        .comment-header {
            flex-shrink: 0;
            padding: 0.5rem;
            background-color: #f8f9fa;
            border-bottom: 1px solid #dee2e6;
        }

        .comment-content {
            flex-grow: 1;
            padding: 0.75rem;
            overflow-y: auto;
            background: white;
        }

        /* Tarjetas de tareas retrasadas */
        .delayed-task-card {
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 1rem;
            background: #f8d7da;
            border: 2px solid #f5c6cb;
            border-radius: 8px;
        }

        /* Grid de medidor de proyecto optimizado */
        .parent_MedidorProyecto {
            display: grid;
            grid-template-columns: auto 1fr auto;
            grid-template-rows: auto auto 1fr;
            gap: 8px;
            height: 100%;
            padding: 0.75rem;
        }

        .div1_MedidorProyecto {
            grid-column: span 3;
            padding: 0.5rem;
            border-radius: 6px;
        }

            .div1_MedidorProyecto h5 {
                margin: 0;
                font-size: 1.1rem;
            }

        .div2_MedidorProyecto {
            grid-column: span 3;
            text-align: center;
            padding: 0.5rem 0;
        }

            .div2_MedidorProyecto h5 {
                margin: 0;
                font-size: 1rem;
                padding-bottom: 0.5rem;
                border-bottom: 1px solid #ccc;
            }

        .div3_MedidorProyecto {
            grid-column: 1;
            grid-row: 3;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .div4_MedidorProyecto {
            grid-column: 3;
            grid-row: 3;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .div5_MedidorProyecto {
            grid-column: 2;
            grid-row: 3;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 120px;
        }

        /* Lista de equipos optimizada */
        .teams-section {
            display: flex;
            flex-direction: column;
            height: 100%;
            padding: 0.75rem;
        }

        .teams-list {
            flex-grow: 1;
            overflow-y: auto;
            margin-top: 0.75rem;
        }

            .teams-list .list-group-item {
                padding: 0.5rem 0.75rem;
                font-size: 0.85rem;
                border: none;
                border-bottom: 1px solid #eee;
            }

                .teams-list .list-group-item:last-child {
                    border-bottom: none;
                }

        /* Controles de carousel originales */
        .carousel-control-prev,
        .carousel-control-next {
            width: 5%; /* más estrecho para no tapar contenido */
            top: 50%;
            transform: translateY(-50%);
        }

        .carousel-control-prev {
            left: -0.6rem; /* más hacia afuera */
        }

        .carousel-control-next {
            right: -0.3rem;
        }

        .carousel-indicators {
            bottom: -30px; /* más abajo */
            /* o usa bottom: 40px; para subirlos si están tapando contenido */
        }

        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            background-image: none; /* quita el ícono por defecto */
            color: #0d6efd; /* azul Bootstrap, cámbialo por el que quieras */
            font-size: 2rem;
        }

            .carousel-control-prev-icon::before {
                content: '‹'; /* flecha izquierda */
            }

            .carousel-control-next-icon::before {
                content: '›'; /* flecha derecha */
            }

        .carousel-indicators [data-bs-target] {
            background-color: #adb5bd; /* gris claro para los no activos */
            width: 4px;
            height: 4px;
            border-radius: 50%;
            margin: 0 4px;
        }

        .carousel-indicators .active {
            background-color: #0d6efd; /* azul Bootstrap para el activo */
        }
   </style>
}


@if (User.Identity.IsAuthenticated)
{
    <div class="container mt-4">
        <div class="welcome-header">
            <h2>Bienvenido/a @User.Identity.Name</h2>
        </div>
        <div class="row">
            <!-- Columna izquierda: Datos del empleado -->
            <div class="col-md-4">
                <div class="card shadow-lg p-3 mb-4 bg-white rounded">
                    <div class="text-center">
                        <!-- Foto -->
                        <img src="~/Resources/administradora.jpg"
                             class="img-fluid rounded-circle mb-3 border border-3 border-primary"
                             alt="Administrador/a" width="120" height="120" />
                        <h5 class="fw-bold text-primary">
                            <i class="fas fa-user"></i> Administrador/a
                        </h5>
                    </div>

                    <div class="card-body">
                        <p class="mb-2">
                            <i class="fas fa-id-badge text-secondary"></i>
                            <strong>Nombre:</strong> @Model.NombreCompleto
                        </p>
                        <p class="mb-2">
                            <i class="fas fa-envelope text-secondary"></i>
                            <strong>Correo:</strong> @Model.Correo
                        </p>
                        <p class="mb-4">
                            <i class="fas fa-calendar-alt text-secondary"></i>
                            <strong>Fecha de Registro:</strong> @Model.FechaRegistro.ToShortDateString()
                        </p>

                        <!-- Lista de equipos -->
                        <div class="card">
                            <div class="card-header bg-primary text-white">
                                <i class="fas fa-users"></i> Equipos
                            </div>
                            <ul class="list-group list-group-flush">
                                @if (Model.Equipos.Any())
                                {
                                    @foreach (var equipo in Model.Equipos)
                                    {
                                        <li class="list-group-item bg-light">
                                            <i class="fas fa-user-friends text-primary"></i>
                                            @equipo.NombreEquipo
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="list-group-item text-muted">
                                        <i class="fas fa-exclamation-circle"></i> No pertenece a ningún equipo.
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="container-fluid col">
                    <!-- Grid principal -->
                    <div class="parent">
                        <!-- Sección de comentarios recientes -->
                        <div class="div1 shadow-sm">
                            <div class="carousel-section">
                                <div class="section-title">
                                    <span class="fw-bold rounded-pill bg-info px-3 py-1">Comentarios Recientes</span>
                                </div>

                                <div class="carousel-container">
                                    <div id="carruselComments" class="carousel slide" data-bs-ride="false">
                                        <div class="carousel-indicators">
                                            @for (int i = 0; i < Model.ComentariosRecientes.Count; i++)
                                            {
                                                <button type="button" data-bs-target="#carruselComments"
                                                        data-bs-slide-to="@i" class="@(i==0? "active": "")"
                                                        aria-current="true" aria-label="Slide @(i+1)">
                                                </button>
                                            }
                                        </div>

                                        <div class="carousel-inner">
                                            @for (int i = 0; i < Model.ComentariosRecientes.Count; i++)
                                            {
                                                <div class="carousel-item @(i==0? "active": "")">
                                                    <div class="comment-card">
                                                        <div class="comment-header">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <div>
                                                                    <span class="rounded-pill bg-info-subtle px-2 py-1 fw-bold">
                                                                        @Model.ComentariosRecientes[i].NombreUsuario
                                                                    </span>
                                                                    <small class="text-secondary ms-2">
                                                                        @Model.ComentariosRecientes[i].FechaRegistro
                                                                    </small>
                                                                </div>
                                                                <span class="rounded-pill bg-warning-subtle px-2 py-1 small">
                                                                    en <strong>@Model.ComentariosRecientes[i].NombreTarea</strong>
                                                                </span>
                                                            </div>
                                                        </div>
                                                        <div class="comment-content">
                                                            <p class="mb-0">@Model.ComentariosRecientes[i].Contenido</p>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>

                                        <button class="carousel-control-prev" type="button" data-bs-target="#carruselComments" data-bs-slide="prev">
                                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                            <span class="visually-hidden">Previous</span>
                                        </button>
                                        <button class="carousel-control-next" type="button" data-bs-target="#carruselComments" data-bs-slide="next">
                                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                            <span class="visually-hidden">Next</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Sección de tareas retrasadas -->
                        <div class="div2 shadow-sm">
                            <div class="carousel-section">
                                <div class="section-title">
                                    <span class="fw-bold rounded-pill bg-info px-3 py-1">Tareas Retrasadas</span>
                                </div>

                                <div class="carousel-container">
                                    <div id="carruselTareas" class="carousel slide" data-bs-ride="false">
                                        <div class="carousel-indicators">
                                            @for (int i = 0; i < Model.TareasFueraDePlazo.Count; i++)
                                            {
                                                <button type="button" data-bs-target="#carruselTareas"
                                                        data-bs-slide-to="@i" class="@(i==0? "active": "")"
                                                        aria-current="true" aria-label="Slide @(i+1)">
                                                </button>
                                            }
                                        </div>

                                        <div class="carousel-inner">
                                            @for (int i = 0; i < Model.TareasFueraDePlazo.Count; i++)
                                            {
                                                <div class="carousel-item @(i==0? "active": "")">
                                                    <div class="delayed-task-card text-center">
                                                        <div class="mb-2">
                                                            <span class="text-dark fw-bold fs-6">
                                                                @Model.TareasFueraDePlazo[i].NombreTareaRetrasada
                                                            </span>
                                                            <div class="badge bg-danger ms-2">
                                                                @Model.TareasFueraDePlazo[i].DiasRetrasada días
                                                            </div>
                                                        </div>
                                                        <div>
                                                            <small class="text-dark">
                                                                Usuario: @Model.TareasFueraDePlazo[i].NombreUsuarioEncargado
                                                            </small>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>

                                        <button class="carousel-control-prev" type="button" data-bs-target="#carruselTareas" data-bs-slide="prev">
                                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                            <span class="visually-hidden">Previous</span>
                                        </button>
                                        <button class="carousel-control-next" type="button" data-bs-target="#carruselTareas" data-bs-slide="next">
                                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                            <span class="visually-hidden">Next</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Sección de gestión de proyectos -->
                        <div class="div3 shadow-sm parent_MedidorProyecto">
                            <div class="div1_MedidorProyecto bg-info bg-gradient">
                                <h5 class="text-dark text-center fw-bolder mb-0">
                                    Gestionar proyectos (@Model.Proyectos.Count)
                                </h5>
                            </div>

                            <div class="div2_MedidorProyecto">
                                <h5 class="text-dark mb-0" id="nombreProyecto">
                                    @(Model.Proyectos.Count > 0 ? Model.Proyectos[0].NombreProyecto : "Sin proyectos")
                                </h5>
                            </div>

                            <div class="div3_MedidorProyecto">
                                <button class="btn btn-dark btn-sm" id="btnPrev">←</button>
                            </div>

                            <div class="div4_MedidorProyecto">
                                <button class="btn btn-dark btn-sm" id="btnNext">→</button>
                            </div>

                            <div class="div5_MedidorProyecto">
                                <canvas id="canvasAvanceProyecto"></canvas>
                            </div>
                        </div>

                        <!-- Sección de equipos -->
                        <div class="div4 shadow-sm">
                            <div class="teams-section">
                                <div class="div1_MedidorProyecto bg-info bg-gradient">
                                    <h5 class="text-dark text-center fw-bolder mb-0">
                                        Equipos con más tareas a Cargo
                                    </h5>
                                </div>

                                <div class="teams-list">
                                    <ul class="list-group list-group-flush">
                                        @foreach (var item in Model.EquiposCnTareas)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                <strong>@item.NombreEquipo</strong>
                                                <span class="badge bg-primary rounded-pill">
                                                    @item.CantidadTareas tareas
                                                </span>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-center align-items-center vh-100">
        <div class="text-center">
            <h1 class="text-danger">ACCESO DENEGADO</h1>
            <p class="text-muted">No tienes permisos para acceder a esta página</p>
        </div>
    </div>
}
@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


    @using System.Text.Json
    @using SistemaProyectos.ViewModels

@{
    
        var jsonProyectos = JsonSerializer.Serialize(Model.Proyectos ?? new List<ProyectoPorcentaje>());
    }
    <script>
        // Fragmento de código de la vista Home/Index
        let grafico = null;
        let color = "orange";
        let proyectos = @Html.Raw(jsonProyectos);
        let indexProyectos = 0;

        function renderCircularChart(id, porcentaje, color) {
            const ctx = document.getElementById(id).getContext("2d");

            if (grafico) {
                grafico.data.datasets[0].data = [porcentaje, 100 - porcentaje];
                grafico.options.plugins.title.text = porcentaje + "%";
                grafico.update();
            } else {
                grafico = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        datasets: [{
                            data: [porcentaje, 100 - porcentaje],
                            backgroundColor: [color, '#e0e0e0'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '50%',
                        plugins: {
                            tooltip: { enabled: false },
                            legend: { display: false },
                            title: {
                                display: true,
                                text: porcentaje + '%',
                                font: { size: 18 },
                                color: '#333'
                            }
                        }
                    }
                });
            }
        }

        renderCircularChart("canvasAvanceProyecto",proyectos[indexProyectos].PorcentajeCompletado, color)
        actualizarVista();

        function actualizarVista() {
            document.getElementById("nombreProyecto").innerText = proyectos[indexProyectos].NombreProyecto;
        }

        document.getElementById("btnPrev").addEventListener("click", () => {
            if (indexProyectos > 0) indexProyectos--;
            renderCircularChart("canvasAvanceProyecto", proyectos[indexProyectos].PorcentajeCompletado, color);
            actualizarVista();
        });

        document.getElementById("btnNext").addEventListener("click", () => {
            if (indexProyectos < proyectos.length - 1) indexProyectos++;
            renderCircularChart("canvasAvanceProyecto", proyectos[indexProyectos].PorcentajeCompletado, color);
            actualizarVista();
        });

    </script>
}
