@model SistemaProyectos.Models.Comentario

@{
    ViewData["Title"] = "Agregar Comentario";
}

<h2 class="text-center">Agregar Comentario</h2>
<hr />

<form asp-action="Comentar" method="post">
    <input type="hidden" asp-for="TareaID" />

    <div class="mb-3">
        <label asp-for="Contenido" class="form-label fw-bold"></label>
        <textarea asp-for="Contenido" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Contenido" class="text-danger"></span>
    </div>

    <div class="text-center">
        <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-paper-plane"></i> Enviar
        </button>
        <a asp-action="Details" asp-route-id="@Model.TareaID" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i> Volver
        </a>
    </div>
</form>
