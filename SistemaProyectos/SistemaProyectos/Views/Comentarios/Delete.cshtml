@model SistemaProyectos.Models.Comentario

@{
    ViewData["Title"] = "Eliminar Comentario";
}

@section Styles {
    <style>
        body {
            background-color: #E6E6FA;
        }
    </style>
}

<h1>@ViewData["Title"]</h1>
<hr />

<h3 class="text-danger text-center">¿Estás seguro que deseas eliminar este comentario?</h3>
<div class="text-center">
    <label>El comentario será eliminado permanentemente de la tarea correspondiente</label>
</div>
<hr />

<div class="row" style="display: block; justify-self: center; width: 600px;">
    <div class="">
        <h4 class="text-center">Información del Comentario</h4>
        <br />
        <table class="table table-bordered table-striped">
            <tbody>
                <tr>
                    <th class="bg-info text-white">Usuario</th>
                    <td>@Model.Usuario?.NombreCompleto</td>
                </tr>
                <tr>
                    <th class="bg-info text-white">Contenido</th>
                    <td>@Model.Contenido</td>
                </tr>
                <tr>
                    <th class="bg-info text-white">Tarea Asociada</th>
                    <td>@Model.Tarea?.Titulo</td>
                </tr>
            </tbody>
        </table>
    </div>
    <hr />
</div>



<form asp-action="Delete" method="post" class="text-center">
    <input type="hidden" asp-for="ComentarioID" />

    <button type="submit" value="Eliminar" class="btn btn-danger">
        <i class="fa-solid fa-trash"></i>&nbsp; Eliminar
    </button>
</form>

<div class="col-2">
    <a class="btn btn-dark" asp-action="Index">
        <i class="fa-solid fa-backward"></i>&nbsp; Regresar
    </a>
</div>
