@model SistemaProyectos.ViewModels.LoginViewModel

@{
    Layout = "~/Views/Shared/_LayoutSinNav.cshtml";
}
<body class="bg-fondo">
    <div class="d-flex justify-content-center align-items-center vh-100 flex-column">

        <div class="card p-4 shadow" style="width: 100%; max-width: 400px;">
            <div class="align-content-center">
                <img src="/Resources/LogoLogin.png" class="img-fluid" style="height:120px; width:300px; object-fit: cover;" />
            </div>

            <hr />
            <h3 class="text-center mb-4">Iniciar Sesión</h3>

            <form asp-action="Login" method="post">
                <div class="col">
                    <label class="form-label">
                        <i class="fa-solid fa-user"></i>&nbsp; Usuario
                    </label>
                    <input asp-for="NombreUsuario" class="form-control mb-2" style="background-color: #E6E6FA" />
                    <span asp-validation-for="NombreUsuario" class="text-danger"></span>
                </div>
                <div class="col">
                    <label class="form-label">
                        <i class="fa-solid fa-asterisk"></i>  &nbsp; Contraseña
                    </label>
                    <input asp-for="Contrasena" type="password" class="form-control mb-2" style="background-color: #E6E6FA" />
                    <span asp-validation-for="Contrasena" class="text-danger"></span>
                </div>
                <br />
                <div class="text-center">
                    <button type="submit" class="btn btn-primary ">
                        <i class="fa-solid fa-right-to-bracket"></i>&nbsp; Ingresar
                    </button>
                    <br />
                    <span class="text-danger">@ViewData["Mensaje"]</span>
                </div>
            </form>
        </div>
    </div>
</body>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
