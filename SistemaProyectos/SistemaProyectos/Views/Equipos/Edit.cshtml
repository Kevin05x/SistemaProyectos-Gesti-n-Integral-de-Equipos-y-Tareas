@model SistemaProyectos.Models.Equipo

@{
    ViewData["Title"] = "Editar un equipo";
}

@section Styles {
    <style>
        body {
            background-color: #E6E6FA;
        }
    </style>
}

<h1>@ViewData["Title"]</h1>


<hr />
<h4 class="text-center">Información del equipo</h4>
<div class="row" style="display:block; justify-self: center;">
    <div class="col-12" style="width: 600px;">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EquipoID" />
            <div class="form-group">
                <label asp-for="NombreEquipo" class="control-label"></label>
                <input asp-for="NombreEquipo" class="form-control" />
                <span asp-validation-for="NombreEquipo" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <label asp-for="Descripcion" class="control-label"></label>
                <textarea asp-for="Descripcion" class="form-control"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="FechaRegistro" hidden class="control-label"></label>
                <input asp-for="FechaRegistro" hidden class="form-control"/>
                <span asp-validation-for="FechaRegistro" hidden class="text-danger"></span>
            </div>

            <hr />
            <div class="form-group text-center">
                <button type="submit" value="Guardar" class="btn btn-warning">
                    <i class="fa-solid fa-floppy-disk"></i>&nbsp; Guardar
                </button>
            </div>
        </form>
    </div>
</div>
<div>
    <a class="btn btn-dark" asp-action="Index">
        <i class="fa-solid fa-backward"></i>&nbsp; Regresar
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
