@model SistemaProyectos.ViewModels.EquipoDetailsViewModel

@{
    ViewData["Title"] = "Detalles del equipo";
    var listaEquipos = ViewBag.ListaEquipos as List<SistemaProyectos.Models.Equipo>;
}

@section Styles {
    <style>
        body {
            background-color: #E6E6FA;
        }
    </style>
}

<h1>@ViewData["Title"]</h1>
<hr />
<div class="row">
    <div class="col-6">
        <h4 class="text-center">Información del equipo</h4>
        <br />
        <table class="table table-bordered table-striped">
            <tbody>
                <tr>
                    <th class="bg-info text-white">Nombre del Equipo</th>
                    <td>@Model.NombreEquipo</td>
                </tr>
                <tr>
                    <th class="bg-info text-white">Descripción</th>
                    <td>@Model.Descripcion</td>
                </tr>
                <tr>
                    <th class="bg-info text-white">Fecha de Registro</th>
                    <td>@Model.FechaRegistro.ToShortDateString()</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="col-6">
        <h4 class="text-center">Integrantes del equipo</h4>
        <br />
        <table class="table table-bordered table-striped">
            <thead class="bg-info text-white align-middle">
                <tr>
                    <th class="bg-info text-white">Nombre</th>
                    <th class="bg-info text-white">Correo</th>
                    <th class="bg-info text-white">Rol</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var usuario in Model.Integrantes)
                {
                    <tr>
                        <td>@usuario.NombreCompleto</td>
                        <td>@usuario.Correo</td>
                        <td>@usuario.Rol
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<hr />
<div class="row">
    <div class="text-center">
        <a asp-action="Edit" asp-route-id="@Model?.EquipoID" class="btn btn-warning">
            <i class="fa-solid fa-pen-to-square"></i>&nbsp; Editar
        </a>
    </div>
</div>

<div class="col-2">
    <a asp-action="Index" class="btn btn-dark">
        <i class="fa-solid fa-backward"></i>&nbsp; Regresar
    </a>
</div>
