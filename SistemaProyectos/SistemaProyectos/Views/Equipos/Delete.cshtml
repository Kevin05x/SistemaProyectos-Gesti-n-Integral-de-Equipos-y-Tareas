@model SistemaProyectos.Models.Equipo

@{
    ViewData["Title"] = "Eliminar Equipo";
    var integrantes = ViewBag.Integrantes as List<SistemaProyectos.Models.Usuario>;
}

@section Styles {
    <style>
        body {
            background-color: #E6E6FA;
        }
    </style>
}

<h1>@ViewData["Title"]</h1>
<hr />

<h3 class="text-danger text-center">¿Estás seguro que deseas eliminar este equipo?</h3>
<div class="text-center">
    <label>El equipo se eliminará con todos sus proyectos, tareas y comentarios correspondientes</label>
</div>
<hr />
<div class="row">
    <div class="col-6">
        <h4 class="text-center">Información del equipo</h4>
        <br />
        <table class="table table-bordered table-striped">
            <tbody>
                <tr>
                    <th class="bg-info text-white">Nombre del Equipo</th>
                    <td>@Model.NombreEquipo</td>
                </tr>
                <tr>
                    <th class="bg-info text-white">Descripción</th>
                    <td>@Model.Descripcion</td>
                </tr>
                <tr>
                    <th class="bg-info text-white">Fecha de Registro</th>
                    <td>@Model.FechaRegistro.ToShortDateString()</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="col-6">
        <h4 class="text-center">Integrantes del equipo</h4>
        <br />
        <table class="table table-bordered table-striped">
            <thead class="bg-info text-white align-middle">
                <tr>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Rol</th>
                </tr>
            </thead>
            <tbody>
                @if (integrantes != null && integrantes.Any())
                {
                    foreach (var usuario in integrantes)
                    {
                        <tr>
                            <td>@usuario.NombreCompleto</td>
                            <td>@usuario.Correo</td>
                            <td>@usuario.Rol</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">No hay integrantes registrados</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<hr />

<form asp-action="Delete" method="post" class="text-center">
    <input type="hidden" asp-for="EquipoID" />
    
    <button type="submit" value="Eliminar" class="btn btn-danger">
        <i class="fa-solid fa-trash"></i>&nbsp; Eliminar
    </button>
</form>

<div class="col-2">
    <a class="btn btn-dark" asp-action="Index">
        <i class="fa-solid fa-backward"></i>&nbsp; Regresar
    </a>
</div>